---
import '../styles/global.css';
import { withBase, links } from '../lib/url';
import ScrollJugglers from '../components/ScrollJugglers.astro';

interface Props {
  title?: string;
  description?: string;
  /** Highlight the active nav item. */
  current?: 'home' | 'standings' | null;
  /** Per-team accent injected onto <body> as CSS vars (used by match pages). */
  accent?: string | null;
  accent2?: string | null;
  updatedAt?: string | null;
}

const {
  title = 'FootStats — FIFA World Cup 2026',
  description = 'Self-updating stats for the FIFA World Cup 2026 — fixtures, group tables, the Golden Boot race, per-match shots-on-target and player stats.',
  current = null,
  accent = null,
  accent2 = null,
  updatedAt = null,
} = Astro.props;

const bodyStyle = [
  accent ? `--team-primary:${accent}` : '',
  accent2 ? `--team-secondary:${accent2}` : '',
]
  .filter(Boolean)
  .join(';');

const updatedLabel = updatedAt
  ? new Date(updatedAt).toLocaleString('en-GB', { day: 'numeric', month: 'short', hour: '2-digit', minute: '2-digit' })
  : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#060c0a" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Barlow+Condensed:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body style={bodyStyle}>
    <ScrollJugglers leftKit={accent2 ?? undefined} rightKit={accent ?? undefined} />

    <header class="site-header">
      <div class="container header-inner">
        <a class="brand" href={links.home()} aria-label="FootStats home">
          <svg class="ball" viewBox="0 0 64 64" aria-hidden="true">
            <circle cx="32" cy="32" r="30" fill="#0e1713" stroke="#27c267" stroke-width="3"></circle>
            <path d="M32 13 l10 7.3 -3.8 11.7 H25.8 L22 20.3 Z" fill="#27c267"></path>
            <circle cx="32" cy="45" r="4.4" fill="#27c267"></circle>
            <circle cx="14.5" cy="30" r="3.2" fill="#3be588"></circle>
            <circle cx="49.5" cy="30" r="3.2" fill="#3be588"></circle>
          </svg>
          <span>Foot<b>Stats</b></span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a class="nav-link" href={links.home()} aria-current={current === 'home' ? 'page' : undefined}>Home</a>
          <a
            class="nav-link"
            href={links.standings()}
            aria-current={current === 'standings' ? 'page' : undefined}>Standings</a
          >
        </nav>
      </div>
    </header>

    <main class="site-main">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>
          <strong>FootStats</strong> · an independent, fan-built stats site for the FIFA World Cup 2026.
          Match data is fetched once after full-time and served statically — no live polling.
        </p>
        <p class="updated">
          {updatedLabel ? `Data updated ${updatedLabel}` : 'Awaiting first data sync'} · runs on ₹0 / free tier
        </p>
      </div>
    </footer>
  </body>
</html>

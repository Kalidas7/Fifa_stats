---
import { fixturesByDate, isFinished, isLive } from '../lib/data';
import { matchIds } from '../lib/matches';
import { teamTheme, readableAccent, teamCode } from '../lib/teams';
import { links } from '../lib/url';
import type { Fixture } from '../lib/types';

interface Props {
  fixtures: Fixture[];
}
const { fixtures } = Astro.props;
const days = fixturesByDate(fixtures);

function dayLabel(iso: string): string {
  const d = new Date(`${iso}T12:00:00Z`);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString('en-GB', {
    weekday: 'short',
    day: 'numeric',
    month: 'short',
    timeZone: 'UTC',
  });
}

function shortRound(f: Fixture): string {
  if (f.group) return `Group ${f.group}`;
  return f.round
    .replace('Round of ', 'R')
    .replace('Quarter-finals', 'QF')
    .replace('Semi-finals', 'SF')
    .replace('3rd Place Final', '3rd')
    .replace('Final', 'Final');
}
---

{
  days.map(({ date, fixtures: dayFx }) => (
    <section class="fx-day">
      <h3 class="fx-day-label">{dayLabel(date)}</h3>
      <div class="fx-list">
        {dayFx.map((f) => {
          const fin = isFinished(f);
          const live = isLive(f);
          const played = fin || live; // has a scoreline to show
          // Only finished fixtures whose match data exists become links (no dead routes).
          const clickable = fin && matchIds.has(f.id);
          const ht = teamTheme(f.home.name);
          const at = teamTheme(f.away.name);
          const Tag = clickable ? 'a' : 'div';
          return (
            <Tag
              class:list={['fixture', { clickable, live }]}
              href={clickable ? links.match(f.id) : undefined}
            >
              <span class="fx-when">
                {live ? (
                  <span class="badge live">{f.status.elapsed ? `${f.status.elapsed}'` : 'LIVE'}</span>
                ) : fin ? (
                  <span class="badge ft">{f.status.short}</span>
                ) : (
                  <time class="js-localtime" datetime={f.utcDate}>
                    {f.utcDate?.slice(11, 16) ?? '—'}
                  </time>
                )}
              </span>

              <span class="fx-team home" style={`--c:${readableAccent(ht)}`}>
                <span class="fx-name">{f.home.name}</span>
                <span class="fx-code">{teamCode(f.home.name) || '—'}</span>
                <span class="fx-dot" aria-hidden="true" />
              </span>

              <span class="fx-score">
                {played ? (
                  <Fragment>
                    <b>{f.home.goals ?? 0}</b>
                    <i>-</i>
                    <b>{f.away.goals ?? 0}</b>
                  </Fragment>
                ) : (
                  <span class="fx-vs">v</span>
                )}
              </span>

              <span class="fx-team away" style={`--c:${readableAccent(at)}`}>
                <span class="fx-dot" aria-hidden="true" />
                <span class="fx-code">{teamCode(f.away.name) || '—'}</span>
                <span class="fx-name">{f.away.name}</span>
              </span>

              <span class="fx-tag">{shortRound(f)}</span>
            </Tag>
          );
        })}
      </div>
    </section>
  ))
}

<script>
  // The static build can't know each viewer's timezone, so kickoff times render as UTC
  // HH:MM and get localized here on load.
  for (const el of document.querySelectorAll('time.js-localtime')) {
    const dt = el.getAttribute('datetime');
    if (!dt) continue;
    const d = new Date(dt);
    if (!Number.isNaN(d.getTime())) {
      el.textContent = d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    }
  }
</script>

<style>
  .fx-day {
    margin-bottom: 22px;
  }

  .fx-day-label {
    font-family: var(--font-head);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--turf-bright);
    margin: 0 0 8px;
    padding-left: 2px;
  }

  .fx-list {
    display: grid;
    gap: 6px;
  }

  .fixture {
    display: grid;
    grid-template-columns: 52px 1fr auto 1fr 56px;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    background: linear-gradient(180deg, var(--surface), var(--bg-2));
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    color: inherit;
  }

  .fixture.clickable {
    cursor: pointer;
    transition: border-color 0.15s, transform 0.15s, background 0.15s;
  }

  .fixture.clickable:hover {
    border-color: var(--line-2);
    transform: translateY(-1px);
  }

  .fixture.live {
    border-color: color-mix(in srgb, var(--live) 45%, var(--line));
  }

  .fx-when {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.9rem;
    color: var(--muted);
    text-align: center;
  }

  .fx-team {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 0;
  }

  .fx-team.home {
    justify-content: flex-end;
    text-align: right;
  }

  .fx-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--c);
    box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.16) inset;
    flex: none;
  }

  .fx-name {
    font-family: var(--font-head);
    font-weight: 600;
    font-size: 0.98rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .fx-code {
    display: none;
    font-family: var(--font-head);
    font-weight: 700;
    font-size: 0.86rem;
    color: var(--c);
    letter-spacing: 0.5px;
  }

  .fx-score {
    font-family: var(--font-display);
    font-size: 1.15rem;
    letter-spacing: 1px;
    white-space: nowrap;
    padding: 1px 8px;
    border-radius: 6px;
    background: var(--surface-3);
    min-width: 46px;
    text-align: center;
  }

  .fx-score i {
    color: var(--faint);
    margin: 0 2px;
    font-style: normal;
  }

  .fx-vs {
    color: var(--faint);
    font-size: 0.9rem;
  }

  .fx-tag {
    font-family: var(--font-head);
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-size: 0.68rem;
    color: var(--faint);
    text-align: right;
    white-space: nowrap;
  }

  /* On narrow screens show codes instead of full names, and drop the round tag. */
  @media (max-width: 560px) {
    .fixture {
      grid-template-columns: 42px 1fr auto 1fr;
      gap: 6px;
      padding: 9px 10px;
    }
    .fx-name {
      display: none;
    }
    .fx-code {
      display: inline;
    }
    .fx-tag {
      display: none;
    }
  }
</style>

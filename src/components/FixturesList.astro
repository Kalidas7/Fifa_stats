---
import { fixturesByDate } from '../lib/data';
import FixtureRow from './FixtureRow.astro';
import type { Fixture } from '../lib/types';

interface Props {
  fixtures: Fixture[];
}
const { fixtures } = Astro.props;
const days = fixturesByDate(fixtures);

function dayLabel(iso: string): string {
  const d = new Date(`${iso}T12:00:00Z`);
  if (Number.isNaN(d.getTime())) return iso;
  return d.toLocaleDateString('en-GB', {
    weekday: 'short',
    day: 'numeric',
    month: 'short',
    timeZone: 'UTC',
  });
}
---

{
  days.map(({ date, fixtures: dayFx }) => (
    <section class="fx-day">
      <h3 class="fx-day-label">{dayLabel(date)}</h3>
      <div class="fx-list">
        {dayFx.map((f) => (
          <FixtureRow f={f} />
        ))}
      </div>
    </section>
  ))
}

<style>
  .fx-day {
    margin-bottom: 22px;
  }

  .fx-day-label {
    font-family: var(--font-head);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--turf-bright);
    margin: 0 0 8px;
    padding-left: 2px;
  }

  .fx-list {
    display: grid;
    gap: 6px;
  }
</style>

---
import Base from '../layouts/Base.astro';
import GroupsPreview from '../components/GroupsPreview.astro';
import GroupTables from '../components/GroupTables.astro';
import FixturesList from '../components/FixturesList.astro';
import GoldenBoot from '../components/GoldenBoot.astro';
import { links } from '../lib/url';
import { teamTheme, readableAccent } from '../lib/teams';
import {
  standings,
  topscorers,
  currentFixtureWindow,
  lastUpdated,
  tournamentMeta,
  champion,
} from '../lib/data';

const windowFx = currentFixtureWindow();
const hasFixtures = windowFx.length > 0;
const hasStandings = standings.length > 0;
const hasScorers = topscorers.length > 0;
const updatedAt = lastUpdated();

// Derive branding from the data (works for any edition the API returns).
const meta = tournamentMeta();
const year = meta.season ?? '';
function fmtRange(a: string | null, b: string | null): string {
  if (!a || !b) return '';
  const o: Intl.DateTimeFormatOptions = { day: 'numeric', month: 'short', timeZone: 'UTC' };
  const da = new Date(a).toLocaleDateString('en-GB', o);
  const db = new Date(b).toLocaleDateString('en-GB', { ...o, year: 'numeric' });
  return `${da} – ${db}`;
}
const dateRange = fmtRange(meta.firstDate, meta.lastDate);
const chips = [
  { n: meta.teamCount, label: 'Teams' },
  { n: meta.groupCount, label: 'Groups' },
  { n: meta.matchCount, label: 'Matches' },
  { n: meta.venueCount, label: 'Stadiums' },
].filter((c) => c.n > 0);

// Champion banner (once the Final is decided).
const champ = champion();
const champAccent = champ ? readableAccent(teamTheme(champ.team.name)) : '';
const champPen = champ?.fixture.penalty;
const champScore = champ
  ? `${champ.fixture.home.goals ?? 0}–${champ.fixture.away.goals ?? 0}${
      champPen ? ` (${champPen.home}–${champPen.away} pen)` : ''
    }`
  : '';
---

<Base current="home" updatedAt={updatedAt}>
  <section class="hero">
    <div class="container">
      <p class="hero-kicker">⚽ FIFA World Cup{dateRange ? ` · ${dateRange}` : ''}</p>
      <h1 class="hero-title">World Cup <span class="accentword">{year}</span><br />Stats, decoded.</h1>
      <p class="hero-sub">
        Fixtures, group tables, the Golden Boot race and per-match shots-on-target — pulled once after
        each final whistle and served static. No live polling, no backend, zero running cost.
      </p>
      {
        chips.length > 0 && (
          <div class="hero-meta">
            {chips.map((c) => (
              <span class="meta-chip">
                <b>{c.n}</b> {c.label}
              </span>
            ))}
          </div>
        )
      }
    </div>
  </section>

  <div class="container">
    {
      champ && (
        <a class="champ-banner" href={links.match(champ.fixture.id)} style={`--c:${champAccent}`}>
          <span class="champ-trophy">🏆</span>
          <span class="champ-main">
            <b>{champ.team.name}</b>
            <span>World Cup {year} Champions</span>
          </span>
          <span class="champ-beat">
            beat {champ.runnerUp.name} {champScore}
          </span>
        </a>
      )
    }

    <!-- FIXTURES -->
    <section class="section" id="fixtures">
      <div class="section-head">
        <h2 class="section-title">Fixtures</h2>
        <span class="section-note">Kickoffs in your local time</span>
      </div>
      {
        hasFixtures ? (
          <Fragment>
            <FixturesList fixtures={windowFx} />
            <p class="more-link">
              <a href={links.standings()}>Full schedule &amp; standings →</a>
            </p>
          </Fragment>
        ) : (
          <div class="empty-state">
            <div class="es-emoji">🗓️</div>
            <h3>Schedule loads after the first sync</h3>
            <p>
              Once the data pipeline runs, all 104 fixtures appear here grouped by day, with live status and
              scores. Finished matches become clickable for full stats.
            </p>
          </div>
        )
      }
    </section>

    <!-- GROUP STANDINGS -->
    <section class="section" id="groups">
      <div class="section-head">
        <h2 class="section-title">Groups</h2>
        <span class="section-note">
          {hasStandings ? 'Top 2 advance · 8 best 3rd-placed too' : 'Final draw · standings update post-match'}
        </span>
      </div>
      {hasStandings ? <GroupTables /> : <GroupsPreview />}
    </section>

    <!-- GOLDEN BOOT -->
    <section class="section" id="golden-boot">
      <div class="section-head">
        <h2 class="section-title">Golden Boot</h2>
        <span class="section-note">Goals · then assists · then minutes</span>
      </div>
      {
        hasScorers ? (
          <GoldenBoot />
        ) : (
          <div class="empty-state">
            <div class="es-emoji">👟</div>
            <h3>The race starts at kickoff</h3>
            <p>The Golden Boot leaderboard fills in as goals go in — ranked by goals, then assists, then minutes.</p>
          </div>
        )
      }
    </section>
  </div>
</Base>

<style>
  .champ-banner {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: clamp(20px, 4vw, 32px);
    padding: 16px 20px;
    border-radius: var(--radius);
    border: 1px solid color-mix(in srgb, var(--c) 45%, var(--line));
    background:
      radial-gradient(90% 160% at 0% 0%, color-mix(in srgb, var(--c) 22%, transparent), transparent 60%),
      linear-gradient(180deg, var(--surface), var(--bg-2));
    transition: transform 0.15s, border-color 0.15s;
  }
  .champ-banner:hover {
    transform: translateY(-2px);
    border-color: var(--c);
  }
  .champ-trophy {
    font-size: 2.2rem;
    filter: drop-shadow(0 2px 6px rgba(0, 0, 0, 0.5));
  }
  .champ-main {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }
  .champ-main b {
    font-family: var(--font-display);
    font-size: clamp(1.4rem, 4vw, 2rem);
    color: var(--c);
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }
  .champ-main span {
    font-family: var(--font-head);
    text-transform: uppercase;
    letter-spacing: 1.2px;
    font-size: 0.78rem;
    font-weight: 700;
    color: var(--gold);
  }
  .champ-beat {
    margin-left: auto;
    text-align: right;
    font-family: var(--font-head);
    font-size: 0.84rem;
    color: var(--muted);
    white-space: nowrap;
  }
  @media (max-width: 520px) {
    .champ-beat {
      display: none;
    }
  }

  .more-link {
    margin-top: 14px;
    text-align: center;
  }
  .more-link a {
    font-family: var(--font-head);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    font-size: 0.85rem;
    color: var(--turf-bright);
    padding: 8px 16px;
    border: 1px solid var(--line-2);
    border-radius: 999px;
    transition: background 0.15s, border-color 0.15s;
  }
  .more-link a:hover {
    background: var(--surface-2);
    border-color: var(--turf);
  }
</style>
